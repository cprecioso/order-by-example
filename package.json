{
  "name": "@cprecioso/order-by-example",
  "version": "0.1.1",
  "type": "module",
  "description": "Build a comparator from example orderings. Give it lists of items in the order you want, and it returns a `compare` function you can hand to `Array.prototype.sort`.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cprecioso/order-by-example.git"
  },
  "homepage": "https://github.com/cprecioso/order-by-example#readme",
  "bugs": {
    "url": "https://github.com/cprecioso/order-by-example/issues"
  },
  "author": "Carlos Precioso <npm@precioso.design>",
  "license": "ISC",
  "packageManager": "yarn@4.15.0",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "docs": "typedoc --plugin typedoc-plugin-mdn-links",
    "prepack": "yarn run build",
    "test": "vitest"
  },
  "devDependencies": {
    "@cprecioso/tsconfig": "^4.0.0",
    "prettier": "3.8.3",
    "prettier-plugin-organize-imports": "4.3.0",
    "prettier-plugin-pkg": "0.22.1",
    "prettier-plugin-sh": "0.18.1",
    "tsdown": "^0.22.0",
    "typedoc": "^0.28.19",
    "typedoc-plugin-mdn-links": "^5.1.1",
    "typescript": "~6.0.3",
    "vitest": "^4.1.6"
  }
}
